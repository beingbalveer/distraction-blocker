{
  "manifest_version": 3,
  "name": "Distraction Blocker",
  "version": "2.0",
  "description": "Hide distracting UI elements on Reddit, YouTube, Instagram, and Facebook. Control what to show and hide from the popup.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Distraction Blocker"
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*", "https://reddit.com/*"],
      "js": ["shared/utils.js", "sites/reddit/content.js"],
      "css": ["sites/reddit/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*", "https://m.youtube.com/*"],
      "js": ["shared/utils.js", "sites/youtube/content.js"],
      "css": ["sites/youtube/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["shared/utils.js", "sites/instagram/content.js"],
      "css": ["sites/instagram/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*", "https://facebook.com/*", "https://m.facebook.com/*"],
      "js": ["shared/utils.js", "sites/facebook/content.js"],
      "css": ["sites/facebook/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}